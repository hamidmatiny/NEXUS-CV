{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Inference Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(nexus_cv_serving_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(nexus_cv_serving_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(nexus_cv_serving_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Active Tracks",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "nexus_cv_active_tracks", "legendFormat": "tracks" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "SLA Breach Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "rate(nexus_cv_sla_breach_total[5m]) / clamp_min(rate(nexus_cv_serving_duration_ms_count[5m]), 1)",
          "legendFormat": "breach rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Anomaly Detections by Camera",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (camera_id) (rate(nexus_cv_anomaly_detections_total[5m]))",
          "legendFormat": "{{camera_id}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Circuit Breaker State",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "nexus_cv_circuit_breaker_state", "legendFormat": "state" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Error Rate by Endpoint",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (endpoint, le) (rate(nexus_cv_serving_duration_ms_bucket{endpoint=~\"/api.*|/health|/metrics\"}[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["nexus-cv", "serving"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "NEXUS-CV Serving",
  "uid": "nexus-cv-serving",
  "version": 1
}
